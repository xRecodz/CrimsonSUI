# ─── Site (optional, for Open Graph / favicon URLs on deploy) ───
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ─── Sui Network ───
NEXT_PUBLIC_SUI_NETWORK=testnet

# ─── Tatum Sui RPC — https://dashboard.tatum.io ───
TATUM_API_KEY=
TATUM_API_KEY_TESTNET=
SUI_RPC_URL=https://sui-mainnet.gateway.tatum.io
# Your Tatum dashboard gateway (testnet)
SUI_RPC_URL_TESTNET=

# ─── Optional public RPC fallback (recommended) ───
SUI_PUBLIC_RPC_TESTNET=https://fullnode.testnet.sui.io:443
SUI_PUBLIC_RPC_MAINNET=https://fullnode.mainnet.sui.io:443

# ─── Sui Deployer (never commit .env.local) ───
SUI_DEPLOYER_PRIVATE_KEY=
SUI_DEPLOYER_ADDRESS=

# ─── Walrus ───
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=5

# After: npm run walrus:upload-pool
NEXT_PUBLIC_QUEST_POOL_BLOB_ID=

# After: npm run sui:deploy (Move publish)
NEXT_PUBLIC_CRIMSON_PACKAGE_ID=
NEXT_PUBLIC_FAUCET_OBJECT_ID=
NEXT_PUBLIC_BADGE_REGISTRY_ID=
NEXT_PUBLIC_STAKING_POOL_ID=

# Hackathon season (UTC ISO)
NEXT_PUBLIC_SEASON_START=2026-05-23T00:00:00.000Z
NEXT_PUBLIC_SEASON_END=2026-06-06T17:00:00.000Z

# Bonus quest XP scaling
NEXT_PUBLIC_BONUS_XP_PER_DFQ=50
NEXT_PUBLIC_BONUS_STAKE_XP_CAP=1000

# Optional — persistent feedback + leaderboard on Vercel
# Vercel → Storage → Marketplace → Upstash → Redis (auto-adds vars below)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Legacy Vercel KV names also work:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

